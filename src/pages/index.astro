---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
  .filter((p) => p.data.section === 'framework')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Group by year
const postsByYear = posts.reduce((acc: Record<string, typeof posts>, post) => {
  const year = post.data.pubDate.getFullYear().toString();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <div class="home-intro">
        <h1>{SITE_TITLE}</h1>
        <p class="tagline">{SITE_DESCRIPTION}</p>
      </div>

      <div class="posts-timeline">
        {
          Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a)).map((year) => { const yearPosts = postsByYear[year]; return (
            <div class="timeline-year-group">
              <h2 class="timeline-year">{year}</h2>
              <ul class="timeline-posts">
                {yearPosts.map((post) => (
                  <li class="timeline-post-item">
                    <time class="timeline-post-date" datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('zh-CN', {
                        month: '2-digit',
                        day: '2-digit',
                      })}
                    </time>
                    <a class="timeline-post-link" href={`/blog/${post.id}/`}>
                      {post.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )})
        }
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .home-intro {
    margin-bottom: 3rem;
  }
  .home-intro h1 {
    font-size: 2.4rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.1rem;
    background: linear-gradient(135deg, var(--heading) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .home-intro .tagline {
    color: var(--text-muted);
    font-size: 1.05rem;
    font-style: italic;
  }

  .posts-timeline {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .timeline-year {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
    padding-bottom: 0.4em;
    border-bottom: 1px solid var(--border);
  }

  .timeline-posts {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline-post-item {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.4rem 0.6rem;
    border-radius: 6px;
    transition: background 0.15s;
    margin: 0 -0.6rem;
  }
  .timeline-post-item:hover {
    background: var(--accent-light);
  }

  .timeline-post-date {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-muted);
    min-width: 50px;
    white-space: nowrap;
  }

  .timeline-post-link {
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
    font-weight: 480;
  }
  .timeline-post-item:hover .timeline-post-link {
    color: var(--accent);
  }
</style>
