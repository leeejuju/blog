---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

// Find related posts sharing at least one category
const allPosts = await getCollection('blog');
const currentCategories: string[] = post.data.categories || [];
const relatedPosts = currentCategories.length > 0
	? allPosts
		.filter((p) => p.id !== post.id)
		.filter((p) => {
			const cats = p.data.categories || [];
			return cats.some((c: string) => currentCategories.includes(c));
		})
		.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	: [];
---

<BlogPost {...post.data} categories={post.data.categories} relatedPosts={relatedPosts}>
	<Content />
</BlogPost>
