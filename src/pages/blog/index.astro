---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const postsByYear = posts.reduce((acc: Record<string, typeof posts>, post) => {
  const year = post.data.pubDate.getFullYear().toString();
  if (!acc[year]) acc[year] = [];
  acc[year].push(post);
  return acc;
}, {});
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`文章 - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1>文章</h1>
      <div class="posts-timeline">
        {
          Object.entries(postsByYear).map(([year, yearPosts]) => (
            <div class="timeline-year-group">
              <h2 class="timeline-year">{year}</h2>
              <ul class="timeline-posts">
                {yearPosts.map((post) => (
                  <li class="timeline-post-item">
                    <time class="timeline-post-date" datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('zh-CN', {
                        month: '2-digit',
                        day: '2-digit',
                      })}
                    </time>
                    <a class="timeline-post-link" href={`/blog/${post.id}/`}>
                      {post.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  h1 {
    margin-bottom: 2rem;
  }
  .posts-timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .timeline-year {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    border-bottom: none;
    color: var(--heading);
  }
  .timeline-posts {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .timeline-post-item {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.35rem 0;
  }
  .timeline-post-date {
    font-family: var(--font-mono, monospace);
    font-size: 0.85rem;
    color: var(--text-muted);
    min-width: 50px;
    white-space: nowrap;
  }
  .timeline-post-link {
    color: var(--link);
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s;
    border-bottom: 1px solid transparent;
  }
  .timeline-post-link:hover {
    color: var(--link-hover);
    border-bottom-color: var(--link-hover);
  }
</style>
