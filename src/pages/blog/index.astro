---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const SECTION_LABELS: Record<string, string> = {
  engineering: '工程实践',
  eval: '基准评测',
  memory: '记忆系统',
  rag: 'RAG',
};

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Group by section → year
const postsBySection = posts.reduce((acc: Record<string, Record<string, typeof posts>>, post) => {
  const section = post.data.section || 'uncategorized';
  const year = post.data.pubDate.getFullYear().toString();
  if (!acc[section]) acc[section] = {};
  if (!acc[section][year]) acc[section][year] = [];
  acc[section][year].push(post);
  return acc;
}, {});

// Sort sections by their most recent pubDate
const sortedSections = Object.keys(postsBySection).sort((a, b) => {
  const newestA = Math.max(...Object.values(postsBySection[a]).flat().map(p => p.data.pubDate.valueOf()));
  const newestB = Math.max(...Object.values(postsBySection[b]).flat().map(p => p.data.pubDate.valueOf()));
  return newestB - newestA;
});
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <BaseHead title={`Framework - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header title="Framework" />
    <main>
      <h1>Framework</h1>
      <p class="section-desc">Agent 框架开发笔记、工具链踩坑与实战记录。</p>
      <div class="posts-timeline">
        {
          sortedSections.map((section) => {
            const years = postsBySection[section];
            const label = SECTION_LABELS[section] || section;
            const sortedYears = Object.keys(years).sort((a, b) => Number(b) - Number(a));
            return (
              <section class="section-group">
                <h2 class="section-title">{label}</h2>
                {sortedYears.map((year) => (
                  <div class="timeline-year-group">
                    <h3 class="timeline-year">{year}</h3>
                    <ul class="timeline-posts">
                      {years[year].map((post) => (
                        <li class="timeline-post-item">
                          <time class="timeline-post-date" datetime={post.data.pubDate.toISOString()}>
                            {post.data.pubDate.toLocaleDateString('zh-CN', {
                              month: '2-digit',
                              day: '2-digit',
                            })}
                          </time>
                          <a class="timeline-post-link" href={`/blog/${post.id}/`}>
                            {post.data.title}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </section>
            );
          })
        }
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  h1 {
    margin-bottom: 0.3rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .section-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 2.5rem;
  }

  .posts-timeline {
    display: flex;
    flex-direction: column;
    gap: 1.8rem;
  }

  .section-group {
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.8rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--accent);
  }

  .timeline-year {
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    padding-bottom: 0.35em;
    border-bottom: 1px solid var(--border);
  }

  .timeline-posts {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .timeline-post-item {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.4rem 0.6rem;
    border-radius: 6px;
    transition: background 0.15s;
    margin: 0 -0.6rem;
  }
  .timeline-post-item:hover {
    background: var(--accent-light);
  }

  .timeline-post-date {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-muted);
    min-width: 50px;
    white-space: nowrap;
  }

  .timeline-post-link {
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s;
    font-weight: 480;
  }
  .timeline-post-item:hover .timeline-post-link {
    color: var(--accent);
  }
</style>
