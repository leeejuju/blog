---
const today = new Date();
---

<footer>
  <div class="footer-links">
    <a href="/rss.xml">RSS</a>
    <span class="sep">NOTHING GREAT SHOULD BE EASY</span>
    <a href="https://github.com/leeejuju" target="_blank" rel="noopener noreferrer">GitHub</a>
  </div>
  <p class="copyright">&copy; {today.getFullYear()} juju</p>
</footer>

<style>
  footer {
    text-align: center;
    padding: 3em 1em 4em 1em;
    color: var(--text-muted);
    font-size: 0.85rem;
    border-top: 1px solid var(--border);
    margin-top: 2em;
  }
  footer a {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  footer a:hover {
    color: var(--accent);
  }
  .footer-links {
    margin-bottom: 0.5em;
    display: flex;
    justify-content: center;
    gap: 0.6em;
  }
  .sep {
    color: var(--border);
  }
  .copyright {
    margin: 0;
    font-size: 0.9em;
  }
</style>
