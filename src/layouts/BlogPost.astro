---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <BaseHead title={title} description={description} image={heroImage} />
  </head>
  <body>
    <Header />
    <div class="post-layout">
      <aside class="toc-sidebar" id="toc-sidebar">
        <nav class="toc-nav">
          <div class="toc-title">目录</div>
          <ul id="toc-list" class="toc-list"></ul>
        </nav>
      </aside>
      <main class="post-main">
        <article>
          <div class="post-header">
            <h1 class="post-title">{title}</h1>
            <div class="post-meta">
              <FormattedDate date={pubDate} />
              {updatedDate && (
                <span class="updated"> · 更新于 <FormattedDate date={updatedDate} /></span>
              )}
            </div>
          </div>
          <div class="prose" id="article-body">
            <slot />
          </div>
        </article>
      </main>
    </div>
    <Footer />
  </body>
</html>

<style>
  /* ── Layout ──────────────────────────── */

  .post-layout {
    display: flex;
    justify-content: center;
    gap: 2rem;
    max-width: 1000px;
    margin: 0 auto;
    padding: 2em 1em 4em 1em;
    animation: fadeIn 0.4s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── TOC Sidebar ─────────────────────── */

  .toc-sidebar {
    width: 220px;
    flex-shrink: 0;
    position: sticky;
    top: 72px;
    align-self: flex-start;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    padding-right: 0.5em;
  }

  .toc-nav {
    font-size: 0.88rem;
  }

  .toc-title {
    font-weight: 700;
    color: var(--heading);
    margin-bottom: 0.75em;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .toc-list li {
    margin-bottom: 2px;
  }

  .toc-list a {
    display: block;
    padding: 3px 8px;
    border-radius: 4px;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    line-height: 1.5;
    transition: color 0.15s, background 0.15s;
    border-left: 2px solid transparent;
  }

  .toc-list a:hover {
    color: var(--heading);
    background: var(--accent-light);
  }

  .toc-list a.active {
    color: var(--accent);
    background: var(--accent-light);
    border-left-color: var(--accent);
  }

  /* h3 items indented */
  .toc-list a[data-level="3"] {
    padding-left: 22px;
    font-size: 0.82rem;
  }

  /* ── Main content ────────────────────── */

  .post-main {
    width: var(--max-width);
    max-width: 100%;
    min-width: 0;
  }

  /* ── Article header ──────────────────── */

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .post-title {
    font-size: 2.2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.3;
    margin-bottom: 0.6rem;
  }

  .post-meta {
    color: var(--text-muted);
    font-size: 0.92rem;
    display: flex;
    align-items: center;
    gap: 0.4em;
  }

  .updated {
    font-style: italic;
  }

  /* ── Prose (article body) ────────────── */

  .prose {
    font-size: 1.05rem;
    line-height: 1.85;
  }

  .prose :global(h2) {
    margin-top: 2.2em;
    font-weight: 700;
  }

  .prose :global(h3) {
    margin-top: 1.8em;
    font-weight: 650;
  }

  .prose :global(p) {
    margin-bottom: 1.2em;
  }

  .prose :global(a) {
    border-bottom: 1px solid var(--border-accent);
  }

  .prose :global(a:hover) {
    border-bottom-color: var(--accent);
  }

  .prose :global(img) {
    margin: 1.5em auto;
    display: block;
  }

  /* ── Responsive ──────────────────────── */

  @media (max-width: 900px) {
    .toc-sidebar {
      display: none;
    }
    .post-layout {
      display: block;
      padding: 1em 1em 3em 1em;
    }
  }

  @media (max-width: 576px) {
    .post-title { font-size: 1.6rem; }
    .prose { font-size: 1rem; }
  }
</style>

<script>
  // Build TOC from article headings
  const article = document.getElementById('article-body');
  const tocList = document.getElementById('toc-list');

  if (article && tocList) {
    const headings = article.querySelectorAll('h2, h3');
    const tocItems: {id: string, text: string, level: string}[] = [];

    headings.forEach((h) => {
      const id = h.getAttribute('id');
      if (id) {
        tocItems.push({ id, text: h.textContent || '', level: h.tagName.toLowerCase() });
      }
    });

    if (tocItems.length > 0) {
      tocItems.forEach((item) => {
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = `#${item.id}`;
        a.textContent = item.text;
        a.setAttribute('data-level', item.level === 'h3' ? '3' : '2');
        li.appendChild(a);
        tocList.appendChild(li);
      });

      // Scroll spy: highlight current section
      const tocAnchors = tocList.querySelectorAll('a');
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const anchor = tocList.querySelector(`a[href="#${entry.target.id}"]`);
            if (entry.isIntersecting) {
              tocAnchors.forEach((a) => a.classList.remove('active'));
              anchor?.classList.add('active');
            }
          });
        },
        { rootMargin: '-80px 0px -70% 0px' }
      );

      headings.forEach((h) => observer.observe(h));
    } else {
      document.querySelector('.toc-sidebar')?.remove();
    }
  } else {
    document.querySelector('.toc-sidebar')?.remove();
  }
</script>
